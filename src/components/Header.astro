---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
  <nav>
    <a class="brand" href="/"><span>BW</span><strong>{SITE_TITLE}</strong></a>
    <div class="links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Articles</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <a href="https://portfolio.buildwithnavneet.com">Portfolio ↗</a>
    </div>
  </nav>
</header>
<style>
header{position:sticky;top:0;z-index:50;background:rgba(243,241,236,.9);backdrop-filter:blur(18px);border-bottom:1px solid #d8d9d5}nav{width:min(1180px,calc(100% - 48px));height:72px;margin:auto;display:flex;align-items:center;justify-content:space-between}.brand{display:flex;align-items:center;gap:11px;color:#1b2430;text-decoration:none}.brand span{width:38px;height:38px;border-radius:12px;display:grid;place-items:center;background:#18202b;color:#f7f5ef;font-size:11px;font-weight:800;letter-spacing:-.04em}.brand strong{font-size:15px}.links{display:flex;align-items:center;gap:22px}.links a{padding:10px 0;color:#687386;text-decoration:none;font-size:12px;font-weight:750}.links a:hover{color:#1b2430}@media(max-width:650px){nav{width:calc(100% - 28px)}.brand strong{display:none}.links{gap:12px}.links a{font-size:10px}}
</style>