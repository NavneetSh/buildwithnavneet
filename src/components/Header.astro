---
import HeaderLink from './HeaderLink.astro';
---
<header>
  <nav>
    <a class="brand" href="/" aria-label="Build With Navneet home"><span class="mark">N</span><span><b>BuildWith</b>Navneet</span></a>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <a href="/#portfolio">Portfolio</a>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <a class="github" href="https://github.com/NavneetSh" target="_blank" rel="noreferrer" aria-label="Navneet Sharma on GitHub">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 .7a11.5 11.5 0 0 0-3.64 22.41c.58.1.79-.25.79-.56v-2.24c-3.22.7-3.9-1.37-3.9-1.37-.52-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.57-.29-5.27-1.28-5.27-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.47.11-3.05 0 0 .97-.31 3.16 1.18a10.9 10.9 0 0 1 5.76 0c2.2-1.49 3.16-1.18 3.16-1.18.63 1.58.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.71 5.38-5.29 5.67.42.36.79 1.07.79 2.16v3.21c0 .31.21.67.8.56A11.5 11.5 0 0 0 12 .7Z"/></svg>
    </a>
  </nav>
</header>
<style>
  header{position:sticky;top:0;z-index:20;background:rgba(255,255,255,.9);backdrop-filter:blur(16px);border-bottom:1px solid #e2e8f0}
  nav{width:min(1180px,calc(100% - 48px));height:72px;margin:auto;display:flex;align-items:center;justify-content:space-between}
  .brand{display:flex;align-items:center;gap:10px;color:#111827;text-decoration:none;font:500 16px/1 ui-sans-serif,system-ui}.brand b{font-weight:800}.mark{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;background:#111827;color:#fff;font:700 17px Georgia}
  .internal-links{display:flex;align-items:center;gap:8px}.internal-links :global(a){padding:26px 12px 22px;color:#64748b;text-decoration:none;font-size:13px;font-weight:600;border-bottom:2px solid transparent}.internal-links :global(a:hover),.internal-links :global(a.active){color:#111827;border-bottom-color:#4f46e5}
  .github{color:#334155;display:flex}.github svg{width:21px;height:21px}
  @media(max-width:650px){nav{width:calc(100% - 28px)}.brand span:last-child{display:none}.internal-links{gap:0}.internal-links :global(a){padding-left:7px;padding-right:7px;font-size:12px}.github{display:none}}
</style>