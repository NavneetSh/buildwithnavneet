---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
  <nav>
    <a class="brand" href="/"><span>BW</span><strong>{SITE_TITLE}</strong></a>
    <div class="links">
      <HeaderLink href="/learn">Learn</HeaderLink>
      <HeaderLink href="/paths">Paths</HeaderLink>
      <HeaderLink href="/series">Series</HeaderLink>
      <HeaderLink href="/labs">Labs</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/resources">Resources</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <a class="search" href="/blog" aria-label="Search and browse articles">Search <kbd>⌘K</kbd></a>
    </div>
  </nav>
</header>
<style>
header{position:sticky;top:0;z-index:50;background:rgba(243,241,236,.92);backdrop-filter:blur(18px);border-bottom:1px solid #d8d9d5}nav{width:min(1240px,calc(100% - 48px));min-height:72px;margin:auto;display:flex;align-items:center;justify-content:space-between;gap:24px}.brand{display:flex;align-items:center;gap:11px;color:#1b2430;text-decoration:none;white-space:nowrap}.brand span{width:38px;height:38px;border-radius:12px;display:grid;place-items:center;background:#18202b;color:#f7f5ef;font-size:11px;font-weight:800;letter-spacing:-.04em}.brand strong{font-size:15px}.links{display:flex;align-items:center;gap:18px}.links a{padding:10px 0;color:#687386;text-decoration:none;font-size:11px;font-weight:750;white-space:nowrap}.links a:hover{color:#1b2430}.search{display:flex;align-items:center;gap:7px!important;border:1px solid #d1d3d0;border-radius:10px;padding:8px 10px!important;background:#faf9f6}kbd{font:9px ui-monospace,monospace;color:#7a8390;background:#eeece7;border:1px solid #d8d9d5;border-radius:5px;padding:2px 5px}@media(max-width:1000px){.links a:nth-child(3),.links a:nth-child(6){display:none}}@media(max-width:760px){nav{width:calc(100% - 28px)}.brand strong{display:none}.links{gap:12px}.links a{font-size:10px}.links a:nth-child(4),.links a:nth-child(5),.links a:nth-child(7){display:none}.search{display:flex!important}}
</style>