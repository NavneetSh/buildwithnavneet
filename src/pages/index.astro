---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const posts = (await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const latest = posts.slice(0,3);
---
<!doctype html><html lang="en"><head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head><body><Header /><main>
<section class="hero"><div class="shell hero-grid"><div><p class="eyebrow">BUILD · LEARN · EXPLAIN</p><h1>Engineering complex systems,<br><em>one layer at a time.</em></h1><p class="lead">Practical field notes on cloud architecture, platform engineering, DevOps, Kubernetes and the infrastructure behind production AI.</p><div class="actions"><a class="primary" href="/blog">Explore articles →</a><a class="secondary" href="https://portfolio.buildwithnavneet.com">View professional profile ↗</a></div></div><div class="terminal"><div class="terminal-top"><span></span><span></span><span></span><small>buildwithnavneet</small></div><div class="terminal-body"><p><i>$</i> whoami</p><strong>Cloud & AI Platform Architect</strong><p><i>$</i> current_focus</p><strong>AI infrastructure · MLOps · Platform engineering</strong><p><i>$</i> philosophy</p><strong>Understand deeply. Build practically. Share clearly.</strong><p class="cursor">_</p></div></div></div></section>
<section class="topics"><div class="shell"><p class="label">CORE TOPICS</p><div class="topic-grid"><article><span>01</span><h3>Cloud Architecture</h3><p>Foundations, landing zones, security, governance and scalable systems.</p></article><article><span>02</span><h3>Platform Engineering</h3><p>Golden paths, Kubernetes, automation and better developer experience.</p></article><article><span>03</span><h3>AI Infrastructure</h3><p>MLOps, LLMOps and the systems required to run AI reliably.</p></article><article><span>04</span><h3>DevOps in Practice</h3><p>CI/CD, infrastructure as code, observability and production lessons.</p></article></div></div></section>
<section class="latest shell"><div class="section-head"><div><p class="eyebrow">LATEST FIELD NOTES</p><h2>What I’m learning<br>and building.</h2></div><a href="/blog">View all articles →</a></div><div class="post-grid">{latest.map((post,index)=><a class="post" href={`/blog/${post.id}/`}><span class="post-no">0{index+1}</span><div><small><FormattedDate date={post.data.pubDate} /></small><h3>{post.data.title}</h3><p>{post.data.description}</p></div><b>↗</b></a>)}</div></section>
<section class="bridge"><div class="shell bridge-grid"><div><p class="eyebrow">BEYOND THE ARTICLES</p><h2>I don’t just write about systems.<br><em>I design and build them.</em></h2></div><div><p>Explore my professional work across cloud architecture, platform engineering and emerging AI infrastructure.</p><a href="https://portfolio.buildwithnavneet.com">Explore my professional profile ↗</a></div></div></section>
</main><Footer /></body></html>
<style is:global>
:root{--bg:#f3f1ec;--card:#faf9f6;--text:#1b2430;--muted:#687386;--border:#d8d9d5;--accent:#5b5aa7;--dark:#18202b}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}.shell{width:min(1180px,calc(100% - 48px));margin:auto}.hero{padding:110px 0 120px}.hero-grid{display:grid;grid-template-columns:1.12fr .88fr;gap:70px;align-items:center}.eyebrow,.label{font:750 10px ui-monospace,monospace;letter-spacing:.17em;color:var(--muted)}.eyebrow:before{content:'';display:inline-block;width:28px;height:1px;background:var(--accent);vertical-align:middle;margin-right:10px}.hero h1,.section-head h2,.bridge h2{font-family:Georgia,serif;font-weight:500;letter-spacing:-.05em}.hero h1{font-size:clamp(56px,6.5vw,88px);line-height:.96;margin:24px 0}.hero em,.bridge em{color:var(--accent);font-weight:400}.lead{max-width:700px;font-size:18px;line-height:1.75;color:var(--muted)}.actions{display:flex;gap:12px;margin-top:34px;flex-wrap:wrap}.actions a,.bridge a{padding:15px 20px;border-radius:14px;text-decoration:none;font-size:12px;font-weight:800}.primary{background:var(--accent);color:white}.secondary{border:1px solid #bfc3c8;color:#3e4856;background:#f8f6f1}.terminal{background:var(--dark);color:#dce3ea;border-radius:24px;box-shadow:0 35px 80px #3038462b;overflow:hidden;transform:rotate(1.5deg)}.terminal-top{height:48px;background:#202a38;display:flex;align-items:center;gap:7px;padding:0 16px}.terminal-top span{width:9px;height:9px;border-radius:50%;background:#657184}.terminal-top small{margin-left:auto;color:#8994a3;font:10px ui-monospace,monospace}.terminal-body{padding:30px;font:12px/1.8 ui-monospace,monospace}.terminal-body p{color:#8f9bad;margin:18px 0 4px}.terminal-body i{color:#aaa7df}.terminal-body strong{font-weight:500}.cursor{animation:blink 1s step-end infinite}.topics{background:#e9ebee;padding:85px 0}.label{text-align:center;margin-bottom:32px}.topic-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}.topic-grid article{background:var(--card);border:1px solid var(--border);border-radius:22px;padding:28px;min-height:230px}.topic-grid span{color:var(--accent);font:700 10px ui-monospace,monospace}.topic-grid h3{margin-top:45px}.topic-grid p{color:var(--muted);font-size:13px;line-height:1.7}.latest{padding:120px 0}.section-head{display:flex;justify-content:space-between;align-items:end;margin-bottom:55px}.section-head h2,.bridge h2{font-size:clamp(42px,5vw,66px);margin:0}.section-head>a{color:var(--text);font-size:12px;font-weight:800}.post-grid{display:grid;gap:12px}.post{display:grid;grid-template-columns:70px 1fr 40px;gap:24px;align-items:center;padding:28px;background:var(--card);border:1px solid var(--border);border-radius:20px;color:var(--text);text-decoration:none;transition:.25s}.post:hover{transform:translateY(-4px);box-shadow:0 20px 50px #30384612}.post-no{font:700 11px ui-monospace,monospace;color:var(--accent)}.post small{color:var(--muted)}.post h3{font-size:22px;margin:6px 0}.post p{color:var(--muted);margin:0}.bridge{background:var(--dark);color:#f2f0ea;padding:110px 0}.bridge-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:80px;align-items:end}.bridge p{color:#aab2bd;line-height:1.8}.bridge a{display:inline-block;background:#f2f0ea;color:var(--dark);margin-top:18px}@keyframes blink{50%{opacity:0}}@media(max-width:900px){.hero-grid,.bridge-grid{grid-template-columns:1fr}.topic-grid{grid-template-columns:1fr 1fr}.section-head{align-items:start;flex-direction:column;gap:20px}}@media(max-width:600px){.shell{width:calc(100% - 28px)}.hero{padding:75px 0}.hero h1{font-size:48px}.topic-grid{grid-template-columns:1fr}.post{grid-template-columns:35px 1fr}.post>b{display:none}}
</style>