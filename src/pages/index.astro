---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const expertise = [
  { icon: '☁', title: 'Cloud Architecture', text: 'Designing secure, scalable cloud platforms and landing zones for modern workloads.', tags: ['Azure', 'AWS', 'Architecture'] },
  { icon: '∞', title: 'DevOps & Platform Engineering', text: 'Building paved roads from source code to production with automation at every layer.', tags: ['Kubernetes', 'Terraform', 'CI/CD'] },
  { icon: '✦', title: 'AI Infrastructure', text: 'Exploring the systems, platforms and MLOps practices that make production AI reliable.', tags: ['MLOps', 'AI Platforms', 'LLMOps'] },
];

const projects = [
  { number: '01', label: 'PLATFORM ENGINEERING', title: 'Enterprise Cloud Landing Zone', text: 'A production-ready cloud foundation with identity, networking, security, governance and automated infrastructure delivery.', tags: ['Terraform', 'Azure', 'DevSecOps'] },
  { number: '02', label: 'AI INFRASTRUCTURE', title: 'Production MLOps Platform', text: 'Reference architecture for taking machine-learning workloads from experimentation to governed production environments.', tags: ['Kubernetes', 'MLOps', 'Observability'] },
  { number: '03', label: 'DEVOPS', title: 'Golden Path Delivery Platform', text: 'Reusable CI/CD patterns and developer workflows that reduce cognitive load and improve deployment confidence.', tags: ['GitHub Actions', 'Containers', 'GitOps'] },
];
---

<!doctype html>
<html lang="en">
  <head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
  <body>
    <Header />
    <main class="home">
      <section class="hero shell">
        <div class="hero-copy">
          <p class="eyebrow"><span></span> CLOUD · DEVOPS · AI INFRASTRUCTURE</p>
          <h1>I build the platforms<br /><em>behind modern technology.</em></h1>
          <p class="intro">I'm <strong>Navneet Sharma</strong>, a Cloud & AI Platform Architect with 12+ years of experience designing infrastructure, automation and engineering platforms that scale.</p>
          <div class="actions">
            <a class="button primary" href="#portfolio">Explore my work <span>↘</span></a>
            <a class="button secondary" href="/blog">Read the blog <span>→</span></a>
          </div>
          <div class="proof"><span><b>12+</b> years in technology</span><span><b>Cloud → AI</b> evolving with the industry</span><span><b>Build in public</b> sharing what I learn</span></div>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="orbit orbit-one"></div><div class="orbit orbit-two"></div><div class="core">B<span>W</span>N</div>
          <div class="float-card card-one"><small>ARCHITECTURE</small><strong>Systems that scale</strong></div>
          <div class="float-card card-two"><small>PHILOSOPHY</small><strong>Learn. Build. Share.</strong></div>
        </div>
      </section>

      <section class="expertise shell">
        <div class="section-heading"><div><p class="eyebrow"><span></span> WHAT I WORK ON</p><h2>Engineering across the stack.</h2></div><p>I work where infrastructure, developer experience and emerging AI systems meet.</p></div>
        <div class="expertise-grid">{expertise.map((item) => <article class="expertise-card"><div class="icon">{item.icon}</div><h3>{item.title}</h3><p>{item.text}</p><div class="tags">{item.tags.map((tag) => <span>{tag}</span>)}</div></article>)}</div>
      </section>

      <section class="portfolio" id="portfolio">
        <div class="shell">
          <div class="section-heading light"><div><p class="eyebrow"><span></span> SELECTED WORK</p><h2>Portfolio & case studies.</h2></div><p>Architecture, automation and platform projects focused on solving real engineering problems.</p></div>
          <div class="project-grid">{projects.map((project) => <article class="project-card"><div class="project-top"><span class="project-number">{project.number}</span><span class="project-label">{project.label}</span></div><div class="project-art"><span>{project.number}</span></div><h3>{project.title}</h3><p>{project.text}</p><div class="tags dark">{project.tags.map((tag) => <span>{tag}</span>)}</div></article>)}</div>
          <p class="portfolio-note">More case studies coming as I document the systems I've built and the lessons behind them.</p>
        </div>
      </section>

      <section class="about-strip shell">
        <p class="eyebrow"><span></span> BUILD WITH NAVNEET</p>
        <div><h2>Learning the future<br />by <em>building it.</em></h2><p>This site is my engineering notebook on the internet — practical deep dives, architecture breakdowns and lessons from more than a decade in technology.</p></div>
        <a class="text-link" href="/about">More about me <span>→</span></a>
      </section>

      <section class="cta shell"><div><p class="eyebrow"><span></span> KEEP LEARNING</p><h2>Ideas, systems and lessons<br />from the engineering frontier.</h2></div><a class="button primary" href="/blog">Explore the blog <span>→</span></a></section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .home{max-width:none;padding:0;width:100%}.shell{width:min(1180px,calc(100% - 48px));margin:auto}.hero{min-height:720px;display:grid;grid-template-columns:1.18fr .82fr;align-items:center;gap:70px;padding-top:70px;padding-bottom:80px}.eyebrow{font:700 12px/1.2 ui-monospace,SFMono-Regular,Menlo,monospace;letter-spacing:.16em;color:#64748b;display:flex;align-items:center;gap:10px;margin:0 0 24px}.eyebrow span{width:28px;height:1px;background:#4f46e5}.hero h1,.section-heading h2,.about-strip h2,.cta h2{font-family:Georgia,'Times New Roman',serif;letter-spacing:-.045em}.hero h1{font-size:clamp(52px,6.2vw,86px);line-height:.98;margin:0;color:#0f172a;font-weight:500}.hero h1 em,.about-strip h2 em{font-weight:400;color:#4f46e5}.intro{font-size:19px;line-height:1.7;max-width:680px;color:#64748b;margin:32px 0}.intro strong{color:#1e293b}.actions{display:flex;gap:12px;flex-wrap:wrap}.button{display:inline-flex;align-items:center;gap:30px;padding:15px 20px;border-radius:6px;text-decoration:none;font-size:14px;font-weight:700}.button.primary{background:#4f46e5;color:#fff}.button.primary:hover{background:#3730a3;color:#fff}.button.secondary{border:1px solid #cbd5e1;color:#334155}.proof{display:flex;gap:30px;margin-top:54px;padding-top:24px;border-top:1px solid #e2e8f0;font-size:12px;color:#94a3b8}.proof span{display:flex;flex-direction:column;gap:3px}.proof b{color:#334155;font-size:13px}.hero-visual{height:500px;position:relative;display:grid;place-items:center;background:radial-gradient(circle at center,rgba(79,70,229,.12),transparent 55%)}.orbit{position:absolute;border:1px solid #cbd5e1;border-radius:50%}.orbit-one{width:360px;height:360px}.orbit-two{width:240px;height:240px}.core{width:145px;height:145px;border-radius:50%;background:#111827;color:white;display:grid;place-items:center;font:500 38px Georgia;box-shadow:0 30px 80px rgba(15,23,42,.25)}.core span{color:#818cf8}.float-card{position:absolute;background:rgba(255,255,255,.9);backdrop-filter:blur(12px);border:1px solid #e2e8f0;padding:16px 18px;box-shadow:0 18px 50px rgba(15,23,42,.1);display:flex;flex-direction:column}.float-card small{font-size:9px;letter-spacing:.14em;color:#94a3b8}.float-card strong{font-size:13px;color:#1e293b}.card-one{top:90px;right:0}.card-two{bottom:85px;left:0}.expertise{padding-top:110px;padding-bottom:130px}.section-heading{display:flex;justify-content:space-between;align-items:end;gap:50px;margin-bottom:55px}.section-heading h2{font-size:clamp(40px,5vw,62px);font-weight:500;margin:0;color:#0f172a}.section-heading>p{max-width:420px;color:#64748b;font-size:16px;line-height:1.7}.expertise-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.expertise-card{border:1px solid #e2e8f0;padding:34px;min-height:300px;transition:.25s}.expertise-card:hover{transform:translateY(-5px);box-shadow:0 24px 60px rgba(15,23,42,.08)}.icon{font-size:27px;color:#4f46e5;margin-bottom:48px}.expertise-card h3,.project-card h3{font-size:21px;color:#0f172a;margin-bottom:12px}.expertise-card p,.project-card p{font-size:14px;line-height:1.7;color:#64748b}.tags{display:flex;flex-wrap:wrap;gap:7px;margin-top:24px}.tags span{font:600 10px ui-monospace,monospace;padding:6px 8px;background:#f1f5f9;color:#64748b}.portfolio{background:#0b1120;padding:120px 0;color:white}.section-heading.light h2{color:white}.section-heading.light .eyebrow,.section-heading.light>p{color:#94a3b8}.project-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.project-card{border:1px solid #253047;padding:24px;background:#101827}.project-top{display:flex;justify-content:space-between;align-items:center}.project-number{font:500 12px ui-monospace;color:#64748b}.project-label{font:700 9px ui-monospace;letter-spacing:.12em;color:#818cf8}.project-art{height:180px;margin:22px 0 28px;background:linear-gradient(135deg,#172033,#111827);display:grid;place-items:center;overflow:hidden}.project-art span{font:500 110px Georgia;color:#202c43;transform:rotate(-10deg)}.project-card h3{color:white}.project-card p{color:#94a3b8}.tags.dark span{background:#182237;color:#94a3b8}.portfolio-note{text-align:center;color:#64748b;font-size:13px;margin:38px 0 0}.about-strip{padding-top:130px;padding-bottom:130px;display:grid;grid-template-columns:.55fr 1.3fr .55fr;gap:40px;align-items:start}.about-strip h2{font-size:clamp(44px,5vw,66px);line-height:1.05;font-weight:500;margin:0}.about-strip>div p{max-width:620px;color:#64748b;font-size:17px;line-height:1.8}.text-link{color:#334155;text-decoration:none;font-weight:700;font-size:14px;justify-self:end;border-bottom:1px solid #cbd5e1;padding-bottom:8px}.cta{margin-bottom:100px;padding-top:70px;padding-bottom:70px;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0;display:flex;align-items:end;justify-content:space-between;gap:40px}.cta h2{font-size:clamp(38px,4vw,54px);font-weight:500;margin:0;line-height:1.1}@media(max-width:900px){.hero{grid-template-columns:1fr;min-height:auto;padding-top:100px}.hero-visual{height:380px}.expertise-grid,.project-grid{grid-template-columns:1fr}.section-heading{align-items:start;flex-direction:column}.about-strip{grid-template-columns:1fr}.text-link{justify-self:start}.proof{flex-wrap:wrap}}@media(max-width:600px){.shell{width:min(100% - 28px,1180px)}.hero{padding-top:70px;gap:20px}.hero h1{font-size:48px}.hero-visual{height:320px}.orbit-one{width:280px;height:280px}.orbit-two{width:190px;height:190px}.core{width:120px;height:120px}.float-card{display:none}.expertise,.portfolio,.about-strip{padding-top:80px;padding-bottom:80px}.expertise-card{min-height:auto}.cta{align-items:start;flex-direction:column}.proof{gap:18px}}
</style>