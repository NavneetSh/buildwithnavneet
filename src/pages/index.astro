---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const posts = (await getCollection('blog')).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const latest = posts.slice(0,3);
const domains = [
  ['AI & LLM Systems','Transformers, tokens, embeddings, RAG, agents and production AI.','/learn#ai-llm'],
  ['AI Infrastructure','GPUs, model serving, inference, MLOps and AI platforms.','/learn#ai-infrastructure'],
  ['Cloud','Architecture, landing zones, identity, networking and governance.','/learn#cloud'],
  ['Platform Engineering','Golden paths, developer platforms and internal tooling.','/learn#platform-engineering'],
  ['Kubernetes','From workload fundamentals to production platform architecture.','/learn#kubernetes'],
  ['Infrastructure as Code','Terraform, automation, reusable modules and delivery systems.','/learn#iac'],
  ['DevOps','CI/CD, observability, reliability and production engineering.','/learn#devops'],
  ['System Architecture','High-level design, low-level design and technical decisions.','/learn#architecture']
];
const paths = [
  ['AI Infrastructure Engineer','Cloud foundations → Kubernetes → GPUs → model serving → production AI','01'],
  ['Platform Engineer','Cloud → containers → Kubernetes → IaC → developer platforms','02'],
  ['Cloud Architect','Networking → identity → compute → data → architecture','03']
];
---
<!doctype html><html lang="en"><head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head><body><Header /><main>
<section class="hero"><div class="shell hero-grid"><div><p class="eyebrow">PUBLIC ENGINEERING KNOWLEDGE SYSTEM</p><h1>Understand deeply.<br><em>Build practically.</em></h1><p class="lead">A structured learning portal for AI infrastructure, cloud architecture, platform engineering and the systems behind modern software.</p><div class="actions"><a class="primary" href="/learn">Start learning →</a><a class="secondary" href="/paths">Choose a learning path</a></div></div><div class="map"><p class="map-label">EXPLORE THE KNOWLEDGE SYSTEM</p><a href="/learn"><span>01</span><div><strong>Learn by domain</strong><small>Explore structured topic libraries</small></div><b>→</b></a><a href="/paths"><span>02</span><div><strong>Follow a path</strong><small>Learn in the right order for a role</small></div><b>→</b></a><a href="/series"><span>03</span><div><strong>Read a series</strong><small>Go deep through connected articles</small></div><b>→</b></a><a href="/labs"><span>04</span><div><strong>Build with labs</strong><small>Turn concepts into working systems</small></div><b>→</b></a></div></div></section>
<section class="domains"><div class="shell"><div class="section-title"><p class="eyebrow">LEARN BY DOMAIN</p><h2>Enter through what<br>you want to understand.</h2><a href="/learn">Explore all domains →</a></div><div class="domain-grid">{domains.map((domain,index)=><a id={domain[2].split('#')[1]} href={domain[2]}><span>{String(index+1).padStart(2,'0')}</span><h3>{domain[0]}</h3><p>{domain[1]}</p><b>↗</b></a>)}</div></div></section>
<section class="paths shell"><div class="section-title"><p class="eyebrow">LEARN BY OUTCOME</p><h2>Choose where you<br>want to go.</h2><a href="/paths">View all paths →</a></div><div class="path-list">{paths.map(path=><a href="/paths"><span>{path[2]}</span><div><h3>{path[0]}</h3><p>{path[1]}</p></div><b>→</b></a>)}</div></section>
<section class="formats"><div class="shell"><div class="section-title compact"><p class="eyebrow">MORE THAN BLOG POSTS</p><h2>One knowledge base.<br>Multiple ways to learn.</h2></div><div class="format-grid"><a href="/series"><small>CONNECTED LEARNING</small><h3>Series</h3><p>Follow a technical subject from first principles to advanced architecture.</p></a><a href="/labs"><small>HANDS-ON PRACTICE</small><h3>Labs</h3><p>Build, verify, troubleshoot and understand real systems step by step.</p></a><a href="/projects"><small>COMPLETE SYSTEMS</small><h3>Projects</h3><p>See how multiple technologies combine into production-grade architectures.</p></a><a href="/blog"><small>ATOMIC KNOWLEDGE</small><h3>Notes & articles</h3><p>Quick discoveries, practical fixes and deep technical explanations.</p></a></div></div></section>
<section class="latest shell"><div class="section-title"><p class="eyebrow">LATEST DEEP DIVES</p><h2>What I’m learning<br>and building.</h2><a href="/blog">Browse all content →</a></div><div class="post-grid">{latest.map((post,index)=><a class="post" href={`/blog/${post.id}/`}><span class="post-no">0{index+1}</span><div><small><FormattedDate date={post.data.pubDate} /></small><h3>{post.data.title}</h3><p>{post.data.description}</p></div><b>↗</b></a>)}</div></section>
<section class="bridge"><div class="shell bridge-grid"><div><p class="eyebrow">THE BIGGER PICTURE</p><h2>Learn the concept.<br><em>See the architecture.</em><br>Build the system.</h2></div><div><p>BuildWithNavneet is designed as a public engineering knowledge system—not a chronological blog. Every article connects to a domain, path, series, lab or project so you always know what to learn next.</p><a href="/learn">Enter the knowledge system →</a></div></div></section>
</main><Footer /></body></html>
<style is:global>
:root{--bg:#f3f1ec;--card:#faf9f6;--text:#1b2430;--muted:#687386;--border:#d8d9d5;--accent:#5b5aa7;--dark:#18202b}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,sans-serif}.shell{width:min(1180px,calc(100% - 48px));margin:auto}.hero{padding:100px 0 115px}.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:75px;align-items:center}.eyebrow{font:750 10px ui-monospace,monospace;letter-spacing:.17em;color:var(--muted)}.eyebrow:before{content:'';display:inline-block;width:28px;height:1px;background:var(--accent);vertical-align:middle;margin-right:10px}.hero h1,.section-title h2,.bridge h2{font-family:Georgia,serif;font-weight:500;letter-spacing:-.05em}.hero h1{font-size:clamp(56px,6.5vw,88px);line-height:.96;margin:24px 0}.hero em,.bridge em{color:var(--accent);font-weight:400}.lead{max-width:700px;font-size:18px;line-height:1.75;color:var(--muted)}.actions{display:flex;gap:12px;margin-top:34px;flex-wrap:wrap}.actions a,.bridge a{padding:15px 20px;border-radius:14px;text-decoration:none;font-size:12px;font-weight:800}.primary{background:var(--accent);color:white}.secondary{border:1px solid #bfc3c8;color:#3e4856;background:#f8f6f1}.map{background:var(--dark);border-radius:24px;padding:22px;box-shadow:0 35px 80px #30384624;transform:rotate(1deg)}.map-label{color:#8994a3;font:700 9px ui-monospace,monospace;letter-spacing:.14em;padding:5px 8px 15px}.map a{display:grid;grid-template-columns:32px 1fr 20px;gap:14px;align-items:center;padding:18px 12px;border-top:1px solid #303b49;color:#dce3ea;text-decoration:none}.map span{color:#aaa7df;font:700 10px ui-monospace,monospace}.map strong{display:block;font-size:14px}.map small{display:block;color:#8994a3;margin-top:5px}.map b{font-weight:400;color:#8994a3}.domains{background:#e9ebee;padding:105px 0}.section-title{position:relative;margin-bottom:48px}.section-title h2{font-size:clamp(42px,5vw,66px);line-height:1;margin:18px 0 0}.section-title>a{position:absolute;right:0;bottom:5px;color:var(--text);font-size:12px;font-weight:800}.domain-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.domain-grid a,.format-grid a{position:relative;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:26px;color:var(--text);text-decoration:none;min-height:230px;transition:.2s}.domain-grid a:hover,.format-grid a:hover{transform:translateY(-4px)}.domain-grid span{color:var(--accent);font:700 10px ui-monospace,monospace}.domain-grid h3{margin-top:42px;font-size:18px}.domain-grid p,.format-grid p{color:var(--muted);font-size:13px;line-height:1.7}.domain-grid b{position:absolute;right:24px;bottom:22px}.paths,.latest{padding:115px 0}.path-list{display:grid;gap:12px}.path-list a,.post{display:grid;grid-template-columns:60px 1fr 35px;gap:24px;align-items:center;padding:26px 30px;background:var(--card);border:1px solid var(--border);border-radius:20px;color:var(--text);text-decoration:none;transition:.2s}.path-list a:hover,.post:hover{transform:translateY(-3px);box-shadow:0 18px 45px #30384610}.path-list span,.post-no{font:700 11px ui-monospace,monospace;color:var(--accent)}.path-list h3,.post h3{font-size:21px;margin:0 0 7px}.path-list p,.post p{color:var(--muted);margin:0;font-size:13px}.formats{background:var(--dark);padding:105px 0}.formats .eyebrow,.formats .section-title h2{color:#f2f0ea}.compact{max-width:650px}.format-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.format-grid a{background:#202a38;border-color:#303b49;color:#f2f0ea}.format-grid small{color:#aaa7df;font:700 9px ui-monospace,monospace;letter-spacing:.12em}.format-grid h3{font:500 30px Georgia,serif;margin:50px 0 12px}.format-grid p{color:#aab2bd}.post-grid{display:grid;gap:12px}.post small{color:var(--muted)}.bridge{background:#dedfdc;padding:110px 0}.bridge-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:80px;align-items:end}.bridge h2{font-size:clamp(42px,5vw,66px);margin:0}.bridge p{color:var(--muted);line-height:1.8}.bridge a{display:inline-block;background:var(--dark);color:#f2f0ea;margin-top:18px}@media(max-width:900px){.hero-grid,.bridge-grid{grid-template-columns:1fr}.domain-grid,.format-grid{grid-template-columns:1fr 1fr}.section-title>a{position:static;display:inline-block;margin-top:20px}}@media(max-width:600px){.shell{width:calc(100% - 28px)}.hero{padding:70px 0}.hero h1{font-size:48px}.domain-grid,.format-grid{grid-template-columns:1fr}.path-list a,.post{grid-template-columns:35px 1fr}.path-list b,.post>b{display:none}}
</style>