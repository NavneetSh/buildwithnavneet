---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const domains=[['ai-llm','AI & LLM Systems','Foundations, transformers, tokenization, embeddings, RAG, agents and production AI.'],['ai-infrastructure','AI Infrastructure','Compute, GPUs, AI networking, storage, training, inference and model serving.'],['cloud','Cloud','Architecture, landing zones, identity, networking, security and governance.'],['platform-engineering','Platform Engineering','Golden paths, internal developer platforms, automation and developer experience.'],['kubernetes','Kubernetes','Architecture, workloads, networking, security, operations and production platforms.'],['iac','Infrastructure as Code','Terraform, modules, state, delivery workflows and enterprise patterns.'],['devops','DevOps','CI/CD, observability, reliability, automation and production engineering.'],['architecture','System Architecture','High-level design, low-level design, trade-offs and technical decisions.']];
---
<!doctype html><html lang="en"><head><BaseHead title="Learn | BuildWithNavneet" description="Explore the BuildWithNavneet knowledge system by technical domain." /></head><body><Header/><main><section class="hero shell"><p>LEARN BY DOMAIN</p><h1>Explore the knowledge system.</h1><div class="grid">{domains.map((d,i)=><a id={d[0]} href="/blog"><span>{String(i+1).padStart(2,'0')}</span><h2>{d[1]}</h2><p>{d[2]}</p><b>Browse content →</b></a>)}</div></section></main><Footer/></body></html><style>:global(body){margin:0;background:#f3f1ec;color:#1b2430;font-family:Inter,system-ui,sans-serif}.shell{width:min(1180px,calc(100% - 48px));margin:auto}.hero{padding:90px 0 120px}.hero>p{font:750 10px ui-monospace,monospace;letter-spacing:.17em;color:#687386}.hero>h1{font:500 clamp(48px,7vw,84px)/1 Georgia,serif;letter-spacing:-.05em;max-width:800px;margin:20px 0 60px}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px}.grid a{background:#faf9f6;border:1px solid #d8d9d5;border-radius:22px;padding:30px;color:#1b2430;text-decoration:none;min-height:260px}.grid span{color:#5b5aa7;font:700 10px ui-monospace,monospace}.grid h2{font:500 30px Georgia,serif;margin:55px 0 12px}.grid p{color:#687386;line-height:1.7;max-width:480px}.grid b{display:block;margin-top:24px;font-size:12px}@media(max-width:700px){.shell{width:calc(100% - 28px)}.grid{grid-template-columns:1fr}}</style>