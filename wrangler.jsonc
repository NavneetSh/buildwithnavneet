{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "buildwithnavneet",
  "compatibility_date": "2026-07-03",
  "assets": {
    "directory": "./dist/client/buildwithnavneet"
  },
  "routes": [
    {
      "pattern": "buildwithnavneet.com",
      "custom_domain": true
    },
    {
      "pattern": "www.buildwithnavneet.com",
      "custom_domain": true
    }
  ]
}
